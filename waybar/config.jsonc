{
    "layer": "top",
    "spacing": 3,
    "height": 30,

    "margin-top": 4,
    "margin-right": 4,
    "margin-bottom": 0,
    "margin-left": 4,

    "modules-left": [
        "custom/launcher",
        "hyprland/workspaces",
        "custom/cava"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "tray",
        "pulseaudio",
        "backlight",
        "network",
        "battery",
    ],

    "include": "~/.config/waybar/modules.jsonc"
}
